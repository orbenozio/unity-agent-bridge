<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <!-- Target .NET 8 (LTS, broadest install base) but run on a newer major runtime
         (9, 10, ...) when 8 is not installed - a machine with only .NET 9 runs the tool
         without installing the .NET 8 runtime. -->
    <RollForward>Major</RollForward>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>UnityAgentBridge</RootNamespace>
    <AssemblyName>unity-agent-bridge-server</AssemblyName>

    <!-- Pack the same binary as a .NET global tool, so the CLI (and the MCP server) can
         install as a clean `unity-agent-bridge` command via `dotnet tool install -g`,
         instead of being invoked as `dotnet <dll>`. -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>unity-agent-bridge</ToolCommandName>
    <PackageId>unity-agent-bridge</PackageId>
    <Version>0.1.1</Version>
  </PropertyGroup>

  <ItemGroup>
    <!-- Official C# MCP SDK (stdio server transport + [McpServerTool] discovery). -->
    <PackageReference Include="ModelContextProtocol" Version="1.4.0" />
    <!-- Brings in the generic host + the console logger used in Program.cs. -->
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.1" />
  </ItemGroup>

</Project>
